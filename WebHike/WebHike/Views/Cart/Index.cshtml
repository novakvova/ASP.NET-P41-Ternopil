@using System.Globalization
@using WebHike.Models.Cart
@model List<CartItemModel>

@{
    ViewData["Title"] = "Кошик";
}

<div class="container py-5">
    <h1 class="fw-bold mb-5">
        Кошик
    </h1>
    <div class="row g-5">
        <div class="col-lg-8">
            @foreach(var item in Model)
            {
                <div class="card border-0 shadow rounded-4 p-4 mb-4">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center">
                            <img src="@($"/images/{item.Image}_432.webp")"
                                 class="img-fluid rounded-4"
                                 style="max-height:180px;object-fit:contain;">
                        </div>

                        <div class="col-md-5">
                            <h3 class="fw-bold">
                                @item.Name
                            </h3>
                            <p class="text-secondary mb-1">
                                @item.CategoryName
                            </p>
                            <span class="badge bg-success">
                                В наявності
                            </span>
                        </div>

                        <div class="col-md-2">
                            <div class="input-group">
                                <button class="btn btn-outline-dark">
                                    −
                                </button>
                                <input class="form-control text-center"
                                       value="@item.Quantity">
                                <button class="btn btn-outline-dark">
                                    +
                                </button>
                            </div>
                        </div>

                        <div class="col-md-2 text-end">
                            <h4 class="fw-bold">
                                @item.Price.ToString("C", new CultureInfo("uk-UA"))
                            </h4>
                            <button class="btn btn-outline-danger rounded-pill mt-2">
                                Видалити
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        
        <div class="col-lg-4">
            <div class="card border-0 shadow rounded-4 p-4 sticky-top"
                 style="top:90px;">
                <h3 class="fw-bold mb-4">
                    Разом
                </h3>
                <div class="d-flex justify-content-between mb-3">
                    <span>Товарів</span>
                    <strong>3</strong>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Доставка</span>
                    <strong>Безкоштовно</strong>
                </div>
                <hr>
                <div class="d-flex justify-content-between fs-4 fw-bold mb-4">
                    <span>До сплати</span>
                    <span>17 997 ₴</span>
                </div>
                <button class="btn btn-dark btn-lg rounded-pill mb-3">
                    Оформити замовлення
                </button>
                <a asp-controller="Products"
                   asp-action="Index"
                   class="btn btn-outline-dark rounded-pill">
                    Продовжити покупки
                </a>
            </div>
        </div>
    </div>
</div>